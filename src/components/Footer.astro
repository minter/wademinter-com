---
import Socials from './Socials.astro'

const year = new Date().getFullYear()
---

<footer class="bg-[var(--color-bg-alt)] dark:bg-gray-800 border-t border-[var(--color-border)] dark:border-gray-700 mt-12">
  <div class="max-w-5xl mx-auto px-6 py-10 text-center">
    <p class="text-[var(--color-text-medium)] dark:text-gray-400 mb-4">
      PA Announcer, Tech Executive, Developer, Speaker. Raleigh, NC
    </p>
    <Socials />
    <p class="text-sm text-[var(--color-text-light)] dark:text-gray-500 mt-6">
      &copy; {year} H. Wade Minter
    </p>
  </div>
</footer>
