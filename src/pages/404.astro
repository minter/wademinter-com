---
import BaseLayout from '../layouts/BaseLayout.astro'
import Hero from '../components/Hero.astro'
---

<BaseLayout title="Page Not Found" description="Sorry – the page you are looking for is not here.">
  <Hero
    title="I'm not supposed to be here."
    subtitle="Sorry – the page you're looking for doesn't exist."
    image="/images/site/skater-in-net.jpg"
  />
  <div class="max-w-3xl mx-auto px-6 py-12 text-center">
    <p class="text-lg text-[var(--color-text-medium)] mb-6">Perhaps you typed the URL incorrectly, or the page may have moved.</p>
    <a href="/" class="inline-block px-8 py-3 bg-[var(--color-accent)] text-white font-semibold rounded-md hover:opacity-90 transition-opacity">
      Head back to the home page
    </a>
  </div>
</BaseLayout>
