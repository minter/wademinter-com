---
import BaseLayout from '../../layouts/BaseLayout.astro'
import { getCollection } from 'astro:content'

const posts = (await getCollection('blog')).sort(
  (a, b) => b.data.date.getTime() - a.data.date.getTime()
)
---

<BaseLayout title="Things I Write" description="Blog posts by Wade Minter.">
  <section class="max-w-3xl mx-auto px-6 py-12">
    <h1 class="text-4xl font-bold tracking-tight mb-8">Things I Write</h1>

    {posts.length === 0 && (
      <p class="text-[var(--color-text-medium)]">No posts yet. Check back soon!</p>
    )}

    <div class="space-y-8">
      {posts.map(post => (
        <article class="group">
          <a href={`/blog/${post.id}`} class="block">
            {post.data.featured_image && (
              <div class="aspect-[2/1] overflow-hidden rounded-lg mb-4">
                <img
                  src={post.data.featured_image}
                  alt={post.data.title}
                  class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-300"
                />
              </div>
            )}
            <h2 class="text-2xl font-bold text-[var(--color-text-dark)] group-hover:text-[var(--color-accent)] transition-colors">
              {post.data.title}
            </h2>
            <time class="text-sm text-[var(--color-text-light)] mt-1 block">
              {post.data.date.toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' })}
            </time>
            <p class="text-[var(--color-text-medium)] mt-2">{post.data.description}</p>
          </a>
        </article>
      ))}
    </div>
  </section>
</BaseLayout>
