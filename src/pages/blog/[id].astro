---
import BaseLayout from '../../layouts/BaseLayout.astro'
import Hero from '../../components/Hero.astro'
import Comments from '@bryanguffey/astro-standard-site/components/Comments.astro'
import { generateDocumentLinkTag } from '@bryanguffey/astro-standard-site'
import { getCollection, render } from 'astro:content'

export async function getStaticPaths() {
  const posts = (await getCollection('blog')).sort(
    (a, b) => b.data.date.getTime() - a.data.date.getTime()
  )

  return posts.map((post, index) => ({
    params: { id: post.id },
    props: {
      post,
      newerPost: posts[index - 1],
      olderPost: posts[index + 1],
    },
  }))
}

const { post, newerPost, olderPost } = Astro.props
const { Content } = await render(post)

const DID = 'did:plc:c7vyv3rfip6mejhnzairvkd3'
const headExtra = post.data.atprotoRkey
  ? generateDocumentLinkTag({ did: DID, documentRkey: post.data.atprotoRkey })
  : undefined

const formatPostDate = (date: Date) =>
  date.toLocaleDateString('en-US', {
    year: 'numeric',
    month: 'long',
    day: 'numeric',
    timeZone: 'America/New_York',
  })
---

<BaseLayout title={post.data.title} description={post.data.description} featuredImage={post.data.featured_image} ogType="article" headExtra={headExtra}>
  {post.data.featured_image && (
    <Hero title={post.data.title} image={post.data.featured_image} />
  )}
  <article class="max-w-3xl mx-auto px-6 py-12 prose">
    <time class="text-sm text-[var(--color-text-light)] block mb-6">
      {formatPostDate(post.data.date)}
    </time>
    <Content />
  </article>

  {(newerPost || olderPost) && (
    <nav class="max-w-3xl mx-auto px-6 pb-12 grid gap-4 sm:grid-cols-2" aria-label="Blog post navigation">
      <div>
        {newerPost && (
          <a href={`/blog/${newerPost.id}`} class="block h-full border border-gray-200 dark:border-gray-800 rounded-lg p-4 hover:border-[var(--color-accent)] transition-colors">
            <span class="text-sm text-[var(--color-text-light)]">Newer Post</span>
            <span class="block font-semibold text-[var(--color-text-dark)] dark:text-white mt-1">{newerPost.data.title}</span>
          </a>
        )}
      </div>
      <div>
        {olderPost && (
          <a href={`/blog/${olderPost.id}`} class="block h-full border border-gray-200 dark:border-gray-800 rounded-lg p-4 hover:border-[var(--color-accent)] transition-colors sm:text-right">
            <span class="text-sm text-[var(--color-text-light)]">Older Post</span>
            <span class="block font-semibold text-[var(--color-text-dark)] dark:text-white mt-1">{olderPost.data.title}</span>
          </a>
        )}
      </div>
    </nav>
  )}

  {post.data.bskyPostUri && (
    <section class="max-w-3xl mx-auto px-6 pb-12">
      <h2 class="text-2xl font-bold mb-6">Comments</h2>
      <Comments
        bskyPostUri={post.data.bskyPostUri}
        canonicalUrl={Astro.url.href}
      />
    </section>
  )}
</BaseLayout>
