---
import BaseLayout from '../../layouts/BaseLayout.astro'
import { getCollection } from 'astro:content'

export async function getStaticPaths({ paginate }) {
  const posts = (await getCollection('blog')).sort(
    (a, b) => b.data.date.getTime() - a.data.date.getTime()
  )

  return paginate(posts, { pageSize: 12 })
}

const { page } = Astro.props

const formatPostDate = (date: Date) =>
  date.toLocaleDateString('en-US', {
    year: 'numeric',
    month: 'long',
    day: 'numeric',
    timeZone: 'America/New_York',
  })
---

<BaseLayout title="Things I Write" description="Blog posts by Wade Minter.">
  <section class="max-w-3xl mx-auto px-6 py-12">
    <div class="flex items-center justify-between mb-8">
      <h1 class="text-4xl font-bold tracking-tight">Blog</h1>
      <a href="/rss.xml" class="text-[var(--color-text-light)] dark:text-gray-500 hover:text-[var(--color-accent)] transition-colors" title="RSS Feed">
        <svg class="w-6 h-6" fill="currentColor" viewBox="0 0 24 24">
          <path d="M6.18 15.64a2.18 2.18 0 012.18 2.18C8.36 19 7.38 20 6.18 20C5 20 4 19 4 17.82a2.18 2.18 0 012.18-2.18M4 4.44A15.56 15.56 0 0119.56 20h-2.83A12.73 12.73 0 004 7.27V4.44m0 5.66a9.9 9.9 0 019.9 9.9h-2.83A7.07 7.07 0 004 12.93V10.1z"/>
        </svg>
        <span class="sr-only">RSS Feed</span>
      </a>
    </div>

    {page.data.length === 0 && (
      <p class="text-[var(--color-text-medium)]">No posts yet. Check back soon!</p>
    )}

    <div class="space-y-8">
      {page.data.map(post => (
        <article class="group">
          <a href={`/blog/${post.id}`} class="block">
            {post.data.featured_image && (
              <div class="aspect-[2/1] overflow-hidden rounded-lg mb-4">
                <img
                  src={post.data.featured_image}
                  alt={post.data.title}
                  class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-300"
                />
              </div>
            )}
            <h2 class="text-2xl font-bold text-[var(--color-text-dark)] dark:text-white group-hover:text-[var(--color-accent)] transition-colors">
              {post.data.title}
            </h2>
            <time class="text-sm text-[var(--color-text-light)] mt-1 block">
              {formatPostDate(post.data.date)}
            </time>
            <p class="text-[var(--color-text-medium)] dark:text-gray-400 mt-2">{post.data.description}</p>
          </a>
        </article>
      ))}
    </div>

    {page.lastPage > 1 && (
      <nav class="flex items-center justify-between border-t border-gray-200 dark:border-gray-800 mt-12 pt-8" aria-label="Blog pagination">
        <div>
          {page.url.prev && (
            <a href={page.url.prev} class="text-[var(--color-text-medium)] hover:text-[var(--color-accent)] transition-colors">
              Newer Posts
            </a>
          )}
        </div>
        <p class="text-sm text-[var(--color-text-light)]">
          Page {page.currentPage} of {page.lastPage}
        </p>
        <div>
          {page.url.next && (
            <a href={page.url.next} class="text-[var(--color-text-medium)] hover:text-[var(--color-accent)] transition-colors">
              Older Posts
            </a>
          )}
        </div>
      </nav>
    )}
  </section>
</BaseLayout>
