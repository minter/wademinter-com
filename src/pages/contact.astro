---
import PageLayout from '../layouts/PageLayout.astro'
---

<PageLayout
  title="Contact Me"
  subtitle="Nobody uses the phone any more. But drop me an email here and I'll get back to you."
  description="Email Wade to get in touch."
  featured_image="/images/site/contact.jpg"
>
  <div class="mb-8">
    <form method="post" action="https://faas-nyc1-2ef2e6cc.doserverless.co/api/v1/web/fn-9c0cb262-5a87-4b3f-affc-e4f730ee927b/site/contact" class="space-y-6">
      <div>
        <label class="block text-sm font-semibold text-[var(--color-text-medium)] dark:text-gray-400 mb-2">Email Address *</label>
        <input type="email" name="email" placeholder="Your email address..." required
          class="w-full px-4 py-3 border border-[var(--color-border)] dark:border-gray-600 dark:bg-gray-800 dark:text-white rounded-md focus:outline-none focus:border-[var(--color-accent)] transition-colors" />
      </div>

      <div>
        <label class="block text-sm font-semibold text-[var(--color-text-medium)] dark:text-gray-400 mb-2">Name *</label>
        <input type="text" name="name" placeholder="Your name..." required
          class="w-full px-4 py-3 border border-[var(--color-border)] dark:border-gray-600 dark:bg-gray-800 dark:text-white rounded-md focus:outline-none focus:border-[var(--color-accent)] transition-colors" />
      </div>

      <div>
        <label class="block text-sm font-semibold text-[var(--color-text-medium)] dark:text-gray-400 mb-2">Message *</label>
        <textarea name="message" placeholder="Your message..." required rows="6"
          class="w-full px-4 py-3 border border-[var(--color-border)] dark:border-gray-600 dark:bg-gray-800 dark:text-white rounded-md focus:outline-none focus:border-[var(--color-accent)] transition-colors"></textarea>
      </div>

      <input type="text" name="_gotcha" style="display: none;" />

      <div class="cf-turnstile" data-sitekey="0x4AAAAAAC10ZE1shD-ft_Eh"></div>

      <div>
        <button type="submit"
          class="px-8 py-3 bg-[var(--color-accent)] text-white font-semibold rounded-md hover:opacity-90 transition-opacity cursor-pointer">
          Send Email
        </button>
      </div>
    </form>
    <script src="https://challenges.cloudflare.com/turnstile/v0/api.js" async defer></script>
  </div>

  <p>I generally reply to emails in a day or two. You can also email me directly at <code>wade AT wademinter DOT com</code>.</p>
</PageLayout>
